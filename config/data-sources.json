{
  "sourceOfTruth": "supermetrics-chatgpt-codex-connector",
  "standaloneSupermetricsRestApi": {
    "enabled": false,
    "reason": "Current Supermetrics license supports ChatGPT/Codex connector access, not standalone /enterprise/v2 REST Query API access."
  },
  "deployment": {
    "githubActionsRole": "deploy-only",
    "refreshRole": "Codex pulls through the connected Supermetrics connector, updates public/data.json and public/realdata.js, commits, and pushes."
  },
  "history": {
    "target": "year-to-date",
    "defaultStart": "2026-01-01",
    "notes": [
      "Instagram, Facebook, and YouTube are pulled from 2026-01-01 forward.",
      "TikTok Organic profile metrics are available from 2026-05-08 in the current Supermetrics connector."
    ]
  },
  "platforms": {
    "instagram": {
      "provider": "supermetrics",
      "connector": "Instagram Insights",
      "status": "live",
      "historyStart": "2026-01-01",
      "accountGuard": {
        "dsId": "IGI",
        "accountId": "17841475238822164",
        "accountName": "Better Dog Supplements by Cesar Millan",
        "expectedMetricHandle": "@betterdogsupplements"
      },
      "requiredMetrics": [
        "views",
        "reach",
        "posts"
      ]
    },
    "facebook": {
      "provider": "supermetrics",
      "connector": "Facebook Insights",
      "status": "live",
      "historyStart": "2026-01-01",
      "accountGuard": {
        "dsId": "FB",
        "accountId": "674626722402999",
        "accountName": "Better Dog Supplements by Cesar Millan",
        "expectedMetricHandle": "Better Dog Supplements",
        "contentUrlMustContain": "674626722402999"
      },
      "requiredMetrics": [
        "views",
        "reach",
        "posts"
      ],
      "viewsMetric": "Page media views organic",
      "reachMetric": "Page media views unique"
    },
    "tiktok": {
      "provider": "supermetrics",
      "connector": "TikTok Organic",
      "status": "live",
      "historyStart": "2026-05-08",
      "accountGuard": {
        "dsId": "TIKBA",
        "freeTextAccount": "betterdogsupplements",
        "expectedUsername": "betterdogsupplements",
        "expectedMetricHandle": "@betterdogsupplements",
        "contentUrlMustContain": "/@betterdogsupplements/"
      },
      "requiredMetrics": [
        "views",
        "reach",
        "posts"
      ],
      "reachMetric": "Reached audience",
      "queryNote": "Profile metrics start on 2026-05-08; video-level top content can timeout, so keep profile totals live and use filtered/smaller post queries."
    },
    "youtube": {
      "provider": "supermetrics",
      "connector": "YouTube Analytics",
      "status": "live",
      "historyStart": "2026-01-01",
      "accountGuard": {
        "dsId": "YT2",
        "accountId": "UC9rUabwMqe2C98J2l1NDz2g",
        "accountName": "Better Dog Supplements by Cesar Millan",
        "expectedMetricHandle": "Better Dog Supplements"
      },
      "requiredMetrics": [
        "views",
        "watchTime",
        "posts"
      ],
      "knownLimitations": [
        "Unique viewers is not available in the current Supermetrics YouTube connector, so YouTube reach is not shown."
      ]
    }
  }
}
