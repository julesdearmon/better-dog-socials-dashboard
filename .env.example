# =============================================================================
# Better Dog Supplements — Social Dashboard — environment configuration
# Copy this file to ".env" and fill in real values as you obtain API access.
# Any platform left blank will automatically fall back to DEMO data.
# Never commit the real .env file (it's already in .gitignore).
# =============================================================================

# Server
PORT=4000

# Set to "true" to force demo data for ALL platforms even if keys are present.
# Useful for screenshots, client previews, and offline development.
USE_DEMO_DATA=true

# -----------------------------------------------------------------------------
# Meta (Instagram + Facebook) — Graph API
# Get these from https://developers.facebook.com  (one app covers both)
# See docs/API_SETUP.md for the step-by-step.
# -----------------------------------------------------------------------------
META_APP_ID=
META_APP_SECRET=
# A long-lived Page access token (the dashboard reads IG/FB metrics through it)
META_ACCESS_TOKEN=

# -----------------------------------------------------------------------------
# TikTok — Display / Business API
# Get these from https://developers.tiktok.com
# -----------------------------------------------------------------------------
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
TIKTOK_ACCESS_TOKEN=

# -----------------------------------------------------------------------------
# YouTube — Data API v3 + Analytics API
# Get the API key / OAuth client from https://console.cloud.google.com
# -----------------------------------------------------------------------------
YOUTUBE_API_KEY=
# OAuth token is required for the Analytics API (watch time, audience, etc.)
YOUTUBE_ACCESS_TOKEN=
